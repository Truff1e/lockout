{
  "type": "minecraft:multi_action",
  "title": {
    "text": "Lockout Settings",
    "color": "yellow",
    "bold": true
  },
  "inputs": [
    {
      "type": "minecraft:number_range",
      "key": "max_time",
      "width": 150,
      "label": "Game Duration",
      "label_format": "%1$s: %2$s min",
      "start": 5,
      "end": 240,
      "step": 5,
      "initial": 90
    },
    {
      "type": "minecraft:number_range",
      "key": "start_time",
      "width": 150,
      "label": "Start Delay",
      "label_format": "%1$s: %2$s sec",
      "start": 15,
      "end": 120,
      "step": 5,
      "initial": 45
    },
    {
      "type": "minecraft:single_option",
      "key": "show_progress",
      "width": 150,
      "label": "Show Progress",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    },
    {
      "type": "minecraft:single_option",
      "key": "allow_pvp",
      "width": 150,
      "label": "Allow PvP",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    },
    {
      "type": "minecraft:single_option",
      "key": "allow_locator",
      "width": 150,
      "label": "Allow Locator",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    },
    {
      "type": "minecraft:single_option",
      "key": "allow_draw",
      "width": 150,
      "label": "Allow Draw",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    },
    {
      "type": "minecraft:single_option",
      "key": "allow_resign",
      "width": 150,
      "label": "Allow Resign",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    },
    {
      "type": "minecraft:single_option",
      "key": "end_on_win",
      "width": 150,
      "label": "End on Win",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    },
    {
      "type": "minecraft:single_option",
      "key": "friendly_fire",
      "width": 150,
      "label": "Friendly Fire",
      "options": [
        {
          "id": "1",
          "display": "True",
          "initial": true
        },
        {
          "id": "0",
          "display": "False"
        }
      ]
    }
  ],
  "can_close_with_escape": true,
  "after_action": "close",
  "pause": false,
  "columns": 2,
  "actions": [
    {
      "label": "Cancel",
      "width": 100
    },
    {
      "label": "Update Settings",
      "width": 100,
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "function lockout:settings/edit {'max_time':'$(max_time)','start_time':'$(start_time)','show_progress':'$(show_progress)','allow_pvp':'$(allow_pvp)','allow_locator':'$(allow_locator)','allow_draw':'$(allow_draw)','allow_resign':'$(allow_resign)','end_on_win':'$(end_on_win)','friendly_fire':'$(friendly_fire)'}"
      }
    }
  ]
}
